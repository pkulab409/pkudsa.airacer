#VRML_SIM R2023b utf8

WorldInfo {
  title "AI Racer Demo"
  basicTimeStep 32
  coordinateSystem "ENU"
}

Viewpoint {
  orientation 1 0 0 1.05
  position 0 15 30
}

Background {
  skyColor [ 0.4 0.7 1.0 ]
}

DirectionalLight {
  direction 1 1 -2
  intensity 1.5
  castShadows FALSE
}

Solid {
  name "ground"
  translation 0 0 -0.1
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.15 0.15 0.15
        roughness 0.95
        metalness 0.0
      }
      geometry Box {
        size 120 100 0.2
      }
    }
  ]
  boundingObject Box {
    size 120 100 0.2
  }
}

Solid {
  name "start_finish_line"
  translation 0 0 0.002
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1 1 1
      }
      geometry Box {
        size 0.3 8 0.004
      }
    }
  ]
}

Solid {
  name "wall_north"
  translation 25 5 0.3
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.9 0.7 0.1 }
      geometry Box { size 60 0.3 0.6 }
    }
  ]
  boundingObject Box { size 60 0.3 0.6 }
}

Solid {
  name "wall_south"
  translation 25 -45 0.3
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.9 0.7 0.1 }
      geometry Box { size 60 0.3 0.6 }
    }
  ]
  boundingObject Box { size 60 0.3 0.6 }
}

Solid {
  name "wall_east"
  translation 52 -20 0.3
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.9 0.7 0.1 }
      geometry Box { size 0.3 50 0.6 }
    }
  ]
  boundingObject Box { size 0.3 50 0.6 }
}

Solid {
  name "wall_west"
  translation -4 -20 0.3
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.9 0.7 0.1 }
      geometry Box { size 0.3 50 0.6 }
    }
  ]
  boundingObject Box { size 0.3 50 0.6 }
}

Robot {
  name "supervisor"
  supervisor TRUE
  controller "supervisor"
  children [
    Camera {
      name "overhead_cam"
      translation 24 -20 60
      rotation 0 1 0 1.5708
      width 640
      height 480
      fieldOfView 1.1
    }
  ]
}

DEF car_1 Robot {
  name "car_1"
  translation -3 -0.5 0.04
  rotation 0 0 1 0
  controller "car"
  customData ""
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1 0.1 0.1
        roughness 0.5
        metalness 0.1
      }
      geometry Box {
        size 0.6 0.4 0.06
      }
    }
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor -0.2 -0.22 0
      }
      device [
        RotationalMotor {
          name "left_motor"
          maxVelocity 40
        }
      ]
      endPoint Solid {
        name "c1_rl"
        translation -0.2 -0.22 0
        rotation 1 0 0 1.5708
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
            geometry Cylinder { radius 0.04 height 0.04 }
          }
        ]
        boundingObject Cylinder { radius 0.04 height 0.04 }
        physics Physics {}
      }
    }
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor -0.2 0.22 0
      }
      device [
        RotationalMotor {
          name "right_motor"
          maxVelocity 40
        }
      ]
      endPoint Solid {
